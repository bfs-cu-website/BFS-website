{
"buildCommand": "pnpm --filter @workspace/bfs-website build",
"outputDirectory": "artifacts/bfs-website/dist/public",
"installCommand": "pnpm install",
"rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://bfs-website.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
