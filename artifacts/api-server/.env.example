# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon, Supabase, Railway Postgres, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Password used to log into the admin panel at /admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Secret key used to sign admin session JWTs — use a long random string
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# ── Optional ──────────────────────────────────────────────────────────────────

# Server port (defaults to 8080 if not set)
# PORT=8080

# Set to "production" on live deployments
# NODE_ENV=production

# Admin session length in hours (default: 8)
# SESSION_DURATION_HOURS=8

# When frontend and API are on different domains (e.g. Vercel + Railway),
# set this to your frontend URL so the browser allows credentialed requests.
# Multiple URLs can be comma-separated.
# ALLOWED_ORIGIN=https://your-site.vercel.app

# ── Replit-only (do NOT set on other platforms) ────────────────────────────────
# Object storage credentials are injected automatically by the Replit sidecar.
# On other platforms you must replace lib/objectStorage.ts with a Cloudinary,
# AWS S3, or Vercel Blob implementation and set the appropriate credentials here.
# PUBLIC_OBJECT_SEARCH_PATHS=
# PRIVATE_OBJECT_DIR=
